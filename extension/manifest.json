{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "0.4.1",
  "description": "__MSG_appDesc__",
  "default_locale": "fr",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "alarms"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": [
        "src/i18n.js",
        "src/theme.js",
        "src/scoring.js",
        "src/mirror.js",
        "src/badge.js",
        "src/adapters/factory.js",
        "src/adapters/chatgpt.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "src/i18n.js",
        "src/theme.js",
        "src/scoring.js",
        "src/mirror.js",
        "src/badge.js",
        "src/adapters/factory.js",
        "src/adapters/claude.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "src/i18n.js",
        "src/theme.js",
        "src/scoring.js",
        "src/mirror.js",
        "src/badge.js",
        "src/adapters/factory.js",
        "src/adapters/gemini.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Prompt Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
